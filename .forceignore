# List files or directories below to ignore them when running force:source:push, force:source:pull, and force:source:status
# More information: https://developer.salesforce.com/docs/atlas.en-us.sfdx_dev.meta/sfdx_dev/sfdx_dev_exclude_source.htm
#

package.xml

# LWC configuration files
**/jsconfig.json
**/.eslintrc.json

# LWC Jest
**/__tests__/**

node_modules/

# JcfsApiAdapter.cls is the only file in the framework that references
# the Appfire JCFS managed-package namespace. Excluded from scratch-org
# deploys because the package isn't installed there - JiraPushDispatcher
# falls back to NoOpJcfsApi via Type.forName when this class is absent.
# Deploy normally to the work org (where the managed package IS installed).
force-app/main/default/classes/JcfsApiAdapter.cls
force-app/main/default/classes/JcfsApiAdapter.cls-meta.xml

# Scratch-org compile blockers. PricebookUtilTest tries to assign to
# PricebookUtil.standardPricebookId which only has a getter (no setter) -
# upstream bug, ignore the test until fixed. PricebookUtil.cls itself
# compiles and is referenced by Utilities, so we keep it.
force-app/main/default/classes/pricing/PricebookUtilTest.cls
force-app/main/default/classes/pricing/PricebookUtilTest.cls-meta.xml

# LogCleanupBatchTest references ATM_Endpoint_Log__c and Block_Trigger_Log__c
# which only exist in the work org. Production LogCleanupBatch is generic
# (dynamic SOQL) and deploys fine.
force-app/main/default/classes/logging/LogCleanUp/LogCleanupBatchTest.cls
force-app/main/default/classes/logging/LogCleanUp/LogCleanupBatchTest.cls-meta.xml
