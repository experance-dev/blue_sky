<?xml version="1.0" encoding="UTF-8" ?>
<FlexiPage xmlns="http://soap.sforce.com/2006/04/metadata">
    <!--
      3-tab layout. Order: Rules → Tests → Error Queue.
      Rules first (most actionable), Tests second (dev/QA tooling),
      Error Queue last (reactive — only relevant when something broke).
    -->
    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentName>c:engagementRuleCoverage</componentName>
                <identifier>c_engagementRuleCoverage</identifier>
            </componentInstance>
        </itemInstances>
        <name>rulesTabContent</name>
        <type>Facet</type>
    </flexiPageRegions>
    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentName>c:engagementTestATouch</componentName>
                <identifier>c_engagementTestATouch</identifier>
            </componentInstance>
        </itemInstances>
        <name>testsTabContent</name>
        <type>Facet</type>
    </flexiPageRegions>
    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentName>c:engagementErrorQueue</componentName>
                <identifier>c_engagementErrorQueue</identifier>
            </componentInstance>
        </itemInstances>
        <name>errorQueueTabContent</name>
        <type>Facet</type>
    </flexiPageRegions>
    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>active</name>
                    <value>true</value>
                </componentInstanceProperties>
                <componentInstanceProperties>
                    <name>body</name>
                    <value>rulesTabContent</value>
                </componentInstanceProperties>
                <componentInstanceProperties>
                    <name>title</name>
                    <value>Rules</value>
                </componentInstanceProperties>
                <componentName>flexipage:tab</componentName>
                <identifier>rulesTab</identifier>
            </componentInstance>
        </itemInstances>
        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>body</name>
                    <value>testsTabContent</value>
                </componentInstanceProperties>
                <componentInstanceProperties>
                    <name>title</name>
                    <value>Tests</value>
                </componentInstanceProperties>
                <componentName>flexipage:tab</componentName>
                <identifier>testsTab</identifier>
            </componentInstance>
        </itemInstances>
        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>body</name>
                    <value>errorQueueTabContent</value>
                </componentInstanceProperties>
                <componentInstanceProperties>
                    <name>title</name>
                    <value>Error Queue</value>
                </componentInstanceProperties>
                <componentName>flexipage:tab</componentName>
                <identifier>errorQueueTab</identifier>
            </componentInstance>
        </itemInstances>
        <name>adminTabs</name>
        <type>Facet</type>
    </flexiPageRegions>
    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>label</name>
                    <value>Tabs</value>
                </componentInstanceProperties>
                <componentInstanceProperties>
                    <name>tabs</name>
                    <value>adminTabs</value>
                </componentInstanceProperties>
                <componentName>flexipage:tabset</componentName>
                <identifier>flexipage_tabset</identifier>
            </componentInstance>
        </itemInstances>
        <name>main</name>
        <type>Region</type>
    </flexiPageRegions>
    <masterLabel>Engagement Admin Console</masterLabel>
    <template>
        <name>flexipage:defaultAppHomeTemplate</name>
    </template>
    <type>AppPage</type>
</FlexiPage>
