/**
 * @description Tests for `EngagementAdminController`. Exercises the full
 *              admin-tool surface — test-a-touch happy path + NoMatch,
 *              rule-coverage aggregation, error-queue retrieval, retry
 *              promotion, and ignore archival. Real DML throughout so the
 *              router + resolver paths are validated end-to-end (no service
 *              mocking — these admin tools exist to validate the real pipeline).
 * @group Engagement Attribution
 * @see EngagementAdminController
 * @author David Wood
 * @since May 2026
 */
@IsTest
private class EngagementAdminControllerTest {
  // ─── Constants ────────────────────────────────────────────────────────────

  private static final String PERMISSION_SET = 'Additional_Permissions_Marketing_Influence_Integration';
  private static final String USER_LAST_NAME = 'EngageAdminTest';
  private static final String TOPIC_CODE = 'TOPIC_NETWORK_MGMT';
  private static final String SARAH_EMAIL = 'sarah.admin@uhc.example.com';
  private static final String STRANGER_EMAIL = 'unknown@nowhere.example.com';
  private static final String LATE_EMAIL = 'late.bind@uhc.example.com';

  // ─── Setup ────────────────────────────────────────────────────────────────

  /**
   * @description Provisions a Standard User with the
   *              `Additional_Permissions_Marketing_Influence_Integration` permission set, then seeds a
   *              minimal Zelis-flavored world (Account, one Contact, one
   *              open Opportunity with the Network Mgmt topic, one Topic).
   */
  @TestSetup
  static void setup() {
    EngagementTestFixtures.disableAllProcessAutomation();
    User u = provisionTestUser();
    System.runAs(u) {
      seedWorld();
    }
  }

  // ─── Tests ────────────────────────────────────────────────────────────────

  /**
   * @description Test-a-touch with a known email resolves to the seeded
   *              Contact and produces at least one signal via the default
   *              Account-Topic routing rule.
   */
  @IsTest
  static void testTouchWithKnownEmailResolvesToContact() {
    System.runAs(getTestUser()) {
      EngagementAdminController.TestTouchInput input = buildInput(
        SARAH_EMAIL,
        TOPIC_CODE
      );

      Test.startTest();
      EngagementAdminController.TestTouchResult result = EngagementAdminController.testTouch(
        input
      );
      Test.stopTest();

      Assert.areEqual(
        'Resolved',
        result.resolutionStatus,
        'Expected the touch to resolve to the seeded Contact.'
      );
      Assert.isNotNull(
        result.contactId,
        'Expected Contact populated when resolution succeeds.'
      );
      Assert.isNotNull(
        result.accountId,
        'Expected Account populated when Contact resolves.'
      );
      Assert.isTrue(
        result.signalsCreated >= 1,
        'Expected at least one signal generated by the default Account-Topic rule.'
      );
      Assert.areEqual(
        result.signalsCreated,
        result.signals.size(),
        'Expected signals list size to match signalsCreated count.'
      );
    }
  }

  /**
   * @description Test-a-touch with an unknown email lands as NoMatch and
   *              produces no signals — admins see exactly what happened.
   */
  @IsTest
  static void testTouchWithUnknownEmailReturnsNoMatch() {
    System.runAs(getTestUser()) {
      EngagementAdminController.TestTouchInput input = buildInput(
        STRANGER_EMAIL,
        null
      );

      Test.startTest();
      EngagementAdminController.TestTouchResult result = EngagementAdminController.testTouch(
        input
      );
      Test.stopTest();

      Assert.areEqual(
        'NoMatch',
        result.resolutionStatus,
        'Expected NoMatch when no Contact exists for the email.'
      );
      Assert.isNull(result.contactId, 'Expected Contact null on NoMatch.');
      Assert.areEqual(
        0,
        result.signalsCreated,
        'Expected no signals when the touch is unresolved.'
      );
    }
  }

  /**
   * @description Rule coverage returns one row per active routing rule, in
   *              priority order. The five seeded rules in
   *              `force-app/main/default/customMetadata/Touch_Routing_Rule.*`
   *              must all surface.
   */
  @IsTest
  static void getRuleCoverageReturnsAllActiveRules() {
    System.runAs(getTestUser()) {
      Test.startTest();
      List<EngagementAdminController.RuleCoverage> rows = EngagementAdminController.getRuleCoverage();
      Test.stopTest();

      Assert.areEqual(
        5,
        rows.size(),
        'Expected all 5 seeded active routing rules to be returned.'
      );
      for (EngagementAdminController.RuleCoverage row : rows) {
        Assert.isTrue(
          row.isActive,
          'Expected only active rules to surface in coverage.'
        );
        Assert.isNotNull(
          row.matchPath,
          'Expected every rule row to expose a match path.'
        );
        Assert.isNotNull(
          row.signalsLast30Days,
          'Expected the signal count to be initialised (zero or more).'
        );
      }
    }
  }

  /**
   * @description Error queue surfaces touches in NoMatch — the most common
   *              state admins need to triage.
   */
  @IsTest
  static void getTouchesWithIssuesReturnsNoMatchTouches() {
    System.runAs(getTestUser()) {
      seedNoMatchTouches(2);

      Test.startTest();
      List<EngagementAdminController.TouchIssue> issues = EngagementAdminController.getTouchesWithIssues(
        50
      );
      Test.stopTest();

      Assert.areEqual(
        2,
        issues.size(),
        'Expected both seeded NoMatch touches to surface in the queue.'
      );
      for (EngagementAdminController.TouchIssue issue : issues) {
        Assert.areEqual(
          'NoMatch',
          issue.resolutionStatus,
          'Expected the queue to return only problem-state touches.'
        );
        Assert.isNotNull(
          issue.touchName,
          'Expected the Engagement Touch auto-number to be populated.'
        );
      }
    }
  }

  /**
   * @description Retry resolution promotes a stale NoMatch touch to
   *              Resolved once the upstream Contact appears, then triggers
   *              routing in the same call.
   */
  @IsTest
  static void retryResolutionFixesAStaleNoMatch() {
    System.runAs(getTestUser()) {
      Engagement_Touch__c stale = new Engagement_Touch__c(
        External_Id__c = 'ADMIN-STALE-' + Crypto.getRandomInteger(),
        Source_System__c = 'Manual',
        Email_At_Touch__c = LATE_EMAIL,
        Occurred_At__c = System.now(),
        Ingested_At__c = System.now(),
        Touch_Type__c = 'Download',
        Persona__c = 'Executive',
        Intent_Level__c = 'High',
        Asset_Name__c = 'Retry Test Whitepaper',
        Is_Active__c = true,
        Resolution_Status__c = 'NoMatch',
        Processing_Status__c = 'New'
      );
      Database.insert(stale, AccessLevel.SYSTEM_MODE);

      // Now seed the matching Contact so the retry resolves.
      Account acct = [
        SELECT Id
        FROM Account
        WHERE Name = 'United Healthcare Admin'
        LIMIT 1
      ];
      Contact lateBind = new Contact(
        FirstName = 'Late',
        LastName = 'Bind',
        Email = LATE_EMAIL,
        AccountId = acct.Id
      );
      Database.insert(lateBind, AccessLevel.SYSTEM_MODE);

      Test.startTest();
      EngagementAdminController.TestTouchResult result = EngagementAdminController.retryResolution(
        stale.Id
      );
      Test.stopTest();

      Assert.areEqual(
        'Resolved',
        result.resolutionStatus,
        'Expected retry to promote the touch to Resolved once the Contact existed.'
      );
      Assert.areEqual(
        lateBind.Id,
        result.contactId,
        'Expected retry to bind the touch to the newly seeded Contact.'
      );
    }
  }

  /**
   * @description Ignore action archives the touch — sets `Is_Active__c=false`,
   *              `Processing_Status__c=Ignored`, stamps `Archived_At__c`,
   *              and stores the admin-supplied reason.
   */
  @IsTest
  static void ignoreTouchSetsArchivedAndInactive() {
    System.runAs(getTestUser()) {
      Engagement_Touch__c stale = new Engagement_Touch__c(
        External_Id__c = 'ADMIN-IGNORE-' + Crypto.getRandomInteger(),
        Source_System__c = 'Manual',
        Email_At_Touch__c = STRANGER_EMAIL,
        Occurred_At__c = System.now(),
        Ingested_At__c = System.now(),
        Touch_Type__c = 'Download',
        Persona__c = 'Other',
        Intent_Level__c = 'Low',
        Is_Active__c = true,
        Resolution_Status__c = 'NoMatch'
      );
      Database.insert(stale, AccessLevel.SYSTEM_MODE);

      Test.startTest();
      EngagementAdminController.ignoreTouch(stale.Id, 'Admin: test data');
      Test.stopTest();

      Engagement_Touch__c reloaded = [
        SELECT
          Is_Active__c,
          Processing_Status__c,
          Archived_At__c,
          Processing_Message__c
        FROM Engagement_Touch__c
        WHERE Id = :stale.Id
        LIMIT 1
      ];
      Assert.areEqual(
        false,
        reloaded.Is_Active__c,
        'Expected ignore to flip Is_Active__c off.'
      );
      Assert.areEqual(
        'Ignored',
        reloaded.Processing_Status__c,
        'Expected processing status to flip to Ignored.'
      );
      Assert.isNotNull(
        reloaded.Archived_At__c,
        'Expected Archived_At__c to be stamped.'
      );
      Assert.areEqual(
        'Admin: test data',
        reloaded.Processing_Message__c,
        'Expected the admin-supplied reason to land in Processing_Message__c.'
      );
    }
  }

  // ─── New tests (David Wood, 2026-05-12) ───────────────────────────────────

  /**
   * @description Null input throws AuraHandledException with the validation
   *              message rather than reaching the DML layer.
   */
  @IsTest
  static void testTouchNullInputThrowsAuraHandled() {
    System.runAs(getTestUser()) {
      Test.startTest();
      Boolean thrown = false;
      try {
        EngagementAdminController.testTouch(null);
      } catch (AuraHandledException e) {
        thrown = true;
      }
      Test.stopTest();
      Assert.isTrue(thrown, 'Expected AuraHandledException on null input.');
    }
  }

  /**
   * @description Blank email throws AuraHandledException at validation.
   */
  @IsTest
  static void testTouchBlankEmailThrowsAuraHandled() {
    System.runAs(getTestUser()) {
      Test.startTest();
      Boolean thrown = false;
      try {
        EngagementAdminController.testTouch(buildInput('', null));
      } catch (AuraHandledException e) {
        thrown = true;
      }
      Test.stopTest();
      Assert.isTrue(thrown, 'Expected AuraHandledException on blank email.');
    }
  }

  /**
   * @description Unknown topic_external_code leaves Topic__c null on the
   *              persisted touch (no exception, just empty topic lookup).
   */
  @IsTest
  static void testTouchWithUnknownTopicCodeLeavesTopicNull() {
    System.runAs(getTestUser()) {
      Test.startTest();
      EngagementAdminController.TestTouchResult result = EngagementAdminController.testTouch(
        buildInput(SARAH_EMAIL, 'BOGUS_TOPIC_CODE')
      );
      Test.stopTest();
      Assert.isNotNull(result, 'Expected a TestTouchResult.');
    }
  }

