  /**
   * @description ignoreTouch with a blank reason stamps the default note
   *              "Ignored by admin." into Processing_Message__c.
   */
  @IsTest
  static void ignoreTouchBlankReasonStampsDefaultNote() {
    System.runAs(getTestUser()) {
      // Seed a touch first
      seedNoMatchTouches(1);
      Engagement_Touch__c t = [
        SELECT Id
        FROM Engagement_Touch__c
        WHERE Processing_Status__c = 'New'
        LIMIT 1
      ];
      Test.startTest();
      EngagementAdminController.ignoreTouch(t.Id, null);
      Test.stopTest();
      Engagement_Touch__c reloaded = [
        SELECT Processing_Message__c
        FROM Engagement_Touch__c
        WHERE Id = :t.Id
      ];
      Assert.areEqual(
        'Ignored by admin.',
        reloaded.Processing_Message__c,
        'Expected default note when reason is blank.'
      );
    }
  }

  /**
   * @description getTouchesWithIssues caps the requested limit at 200 and
   *              uses 50 as the default when null is passed.
   */
  @IsTest
  static void getTouchesWithIssuesNullLimitUsesDefault() {
    System.runAs(getTestUser()) {
      seedNoMatchTouches(3);
      Test.startTest();
      List<EngagementAdminController.TouchIssue> result = EngagementAdminController.getTouchesWithIssues(
        null
      );
      Test.stopTest();
      Assert.isTrue(
        result.size() >= 3,
        'Expected at least the 3 seeded NoMatch touches.'
      );
    }
  }

  // ─── Helpers ──────────────────────────────────────────────────────────────

  private static EngagementAdminController.TestTouchInput buildInput(
    String email,
    String topicCode
  ) {
    EngagementAdminController.TestTouchInput input = new EngagementAdminController.TestTouchInput();
    input.email = email;
    input.topicExternalCode = topicCode;
    input.touchType = 'Download';
    input.persona = 'Executive';
    input.intentLevel = 'High';
    input.assetName = 'Admin Test Whitepaper';
    return input;
  }

  private static void seedNoMatchTouches(Integer count) {
    List<Engagement_Touch__c> rows = new List<Engagement_Touch__c>();
    for (Integer i = 0; i < count; i++) {
      rows.add(
        new Engagement_Touch__c(
          External_Id__c = 'ADMIN-NM-' + i + '-' + Crypto.getRandomInteger(),
          Source_System__c = 'Manual',
          Email_At_Touch__c = STRANGER_EMAIL,
          Occurred_At__c = System.now(),
          Ingested_At__c = System.now(),
          Touch_Type__c = 'Download',
          Persona__c = 'Executive',
          Intent_Level__c = 'Medium',
          Is_Active__c = true,
          Resolution_Status__c = 'NoMatch',
          Processing_Status__c = 'New'
        )
      );
    }
    Database.insert(rows, AccessLevel.SYSTEM_MODE);
  }

  private static User provisionTestUser() {
    Profile standard = [
      SELECT Id
      FROM Profile
      WHERE Name = 'Standard User'
      LIMIT 1
    ];
    User u = new User(
      ProfileId = standard.Id,
      LastName = USER_LAST_NAME,
      Email = 'engageadmin@test.example.com',
      Username = 'engageadmin' +
        Crypto.getRandomInteger() +
        '@test.example.com',
      CompanyName = 'TEST',
      Title = 'tester',
      Alias = 'engadm',
      TimeZoneSidKey = 'America/Los_Angeles',
      EmailEncodingKey = 'UTF-8',
      LanguageLocaleKey = 'en_US',
      LocaleSidKey = 'en_US'
    );
    Database.insert(u, AccessLevel.SYSTEM_MODE);
    PermissionSet ps = [
      SELECT Id
      FROM PermissionSet
      WHERE Name = :PERMISSION_SET
      LIMIT 1
    ];
    Database.insert(
      new PermissionSetAssignment(AssigneeId = u.Id, PermissionSetId = ps.Id),
      AccessLevel.SYSTEM_MODE
    );
    return u;
  }

  private static void seedWorld() {
    Touch_Topic__c topic = new Touch_Topic__c(
      Name = 'Network Management',
      Topic_Name__c = 'Network Management',
      External_Code__c = TOPIC_CODE
    );
    Database.insert(topic, AccessLevel.SYSTEM_MODE);

    Account acct = new Account(Name = 'United Healthcare Admin');
    Database.insert(acct, AccessLevel.SYSTEM_MODE);

    Contact sarah = new Contact(
      FirstName = 'Sarah',
      LastName = 'Admin',
      Title = 'CFO',
      Email = SARAH_EMAIL,
      AccountId = acct.Id
    );
    Database.insert(sarah, AccessLevel.SYSTEM_MODE);

    Opportunity opp = new Opportunity(
      Name = 'Network Pricing Implementation',
      AccountId = acct.Id,
      StageName = 'Proposal/Price Quote',
      CloseDate = Date.today().addDays(60),
      Amount = 850000,
      Touch_Topic__c = topic.Id
    );
    Database.insert(opp, AccessLevel.SYSTEM_MODE);
  }

  private static User getTestUser() {
    return [
      SELECT Id
      FROM User
      WHERE LastName = :USER_LAST_NAME
      ORDER BY CreatedDate DESC
      LIMIT 1
    ];
  }
}
