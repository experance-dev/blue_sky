    <description
  >Grants read access to engagement attribution objects and the ability to add contacts to opportunity deal teams (OpportunityContactRole).</description>
    <!-- Standard-field FLS read (2026-05-13): EngagementTouchesSelector + -->
    <!-- EngagementServiceImpl query these under WITH USER_MODE. Without -->
    <!-- explicit read, USER_MODE strips them and DTO assembly returns nulls. -->
    <!-- Account.Name omitted: required field, deploy fails with -->
    <!-- "cannot deploy to a required field" — already readable via object read. -->
    <fieldPermissions>
        <!-- queryAcrsByContact: AccountContactRelation.IsDirect -->
        <editable>false</editable>
        <field>AccountContactRelation.IsDirect</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- queryAcrsByContact: AccountContactRelation.Roles → DTO.acrRole -->
        <editable>false</editable>
        <field>AccountContactRelation.Roles</field>
        <readable>true</readable>
    </fieldPermissions>
    <!-- Contact.FirstName / Contact.LastName omitted: org rejects FLS deploy for -->
    <!-- both (LastName required, FirstName "Invalid field permission"). Contact.Name -->
    <!-- compound is granted implicitly via object read. -->
    <fieldPermissions>
        <!-- EngagementTouchesSelector static SOQL selects Contact.Is_Consultant__c -->
        <!-- under USER_MODE; without FLS read the field strips and consultant -->
        <!-- routing/DTO assembly fail. Added 2026-05-13 alongside Boomer's USER_MODE fix. -->
        <editable>false</editable>
        <field>Contact.Is_Consultant__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- DTO.title — primary fix that prompted this audit -->
        <editable>false</editable>
        <field>Contact.Title</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Engagement_Dismissal__c.Account__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Engagement_Dismissal__c.Opportunity__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Engagement_Dismissal__c.Reason__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <!-- BUG-1 fix (2026-05-12): every Engagement_Touch__c field below is written -->
    <!-- by production code under AccessLevel.USER_MODE. With editable=false the -->
    <!-- Integration User and any UI user assigned this permset cannot ingest a   -->
    <!-- touch or run routing. See docs/test-audit-2026-05-12.md §7 BUG-1.        -->
    <fieldPermissions>
        <!-- IdentityResolutionService.applyResolution; LeadEngagementReparentHandler.reparentTouches -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Account__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementTouchArchivalBatch.execute; EngagementAdminController.ignoreTouch -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Archived_At__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementInboundRest.buildTouches (asset_name from inbound payload) -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Asset_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementInboundRest.buildTouches (asset_url from inbound payload) -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Asset_Url__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementInboundRest.buildTouches (resolved Campaign lookup) -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Campaign__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- IdentityResolutionService.applyResolution; LeadEngagementReparentHandler.reparentTouches -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Contact__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementInboundRest.buildTouches (email is the resolution key — PII; -->
        <!-- write access is required for ingest and intentionally retained on this permset) -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Email_At_Touch__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementInboundRest.buildTouches and EngagementAdminController.testTouch -->
        <!-- both set System.now(); field is DateTime with defaultValue=NOW() but is -->
        <!-- explicitly assigned by code, so FLS edit is required -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Ingested_At__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementInboundRest.buildTouches (intent_level from inbound payload) -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Intent_Level__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- EngagementInboundRest.buildTouches (defaults true on insert); -->
        <!-- EngagementTouchArchivalBatch.execute flips to false; EngagementAdminController.ignoreTouch -->
        <editable>true</editable>
        <field>Engagement_Touch__c.Is_Active__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <!-- IdentityResolutionService.applyResolution; LeadEngagementReparentHandler.reparentTouches (nulls on convert) -->
