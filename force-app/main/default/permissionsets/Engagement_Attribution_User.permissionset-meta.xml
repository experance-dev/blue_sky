<?xml version="1.0" encoding="UTF-8"?>
<!--
  @author       David Wood
  @description  End-user permset for Engagement Attribution (Q9 split).
                Grants READ on engagement objects, READ on signals, access to
                user-facing components. Does NOT include admin-only perms
                (CMDT edit, Touch_Topic create/edit, Engagement Admin app/tab).

                Admin-side perms live in Engagement_Attribution_Admin.

                TODO: Add fieldPermissions / objectPermissions / classAccesses /
                tabSettings for Engagement_Touch__c, Engagement_Dismissal__c,
                Touch_Topic__c, Opportunity_Engagement_Signal__c once the
                Engagement Attribution feature is deployed to this org. Until
                then, this permset declares the user-side label only so it can
                be assigned and validated.
-->
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>End-user access to Engagement Attribution: read engagement touches and signals, see attribution UI on Opportunity/Account/Contact. No admin/config rights. Split from prior combined permset (Q9).</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Engagement Attribution User</label>
</PermissionSet>
