<?xml version="1.0" encoding="UTF-8" ?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <description
  >Salesperson view: every Engagement Touch on my Accounts in the last 30 days, grouped by Contact then by Account. Useful for "what's been happening on my book" without leaving the Reports tab. Scope assumes Account ownership ≈ rep ownership; rework to Opportunity-owner scope if Zelis uses a different model.</description>
    <columns>
        <field>Engagement_Touch__c.Name</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Asset_Name__c</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Touch_Type__c</field>
    </columns>
    <columns>
        <field>Touch_Topic__c.Topic_Name__c</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Persona__c</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Intent_Level__c</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Occurred_At__c</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Resolution_Status__c</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>Engagement_Touch__c.Is_Active__c</column>
            <operator>equals</operator>
            <value>1</value>
        </criteriaItems>
    </filter>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>None</dateGranularity>
        <field>Contact.NAME</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <groupingsDown>
        <dateGranularity>None</dateGranularity>
        <field>Account.NAME</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <name>Recent Engagement Activity on My Pipeline</name>
    <params>
        <name>co</name>
        <value>1</value>
    </params>
    <reportType>Engagement_Touches_with_Account_Contact</reportType>
    <scope>user</scope>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <timeFrameFilter>
        <dateColumn>Engagement_Touch__c.Occurred_At__c</dateColumn>
        <interval>INTERVAL_LAST30</interval>
    </timeFrameFilter>
</Report>
