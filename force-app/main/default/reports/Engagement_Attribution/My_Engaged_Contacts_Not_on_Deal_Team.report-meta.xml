    </columns>
    <columns>
        <field>Opportunity__c.STAGE_NAME</field>
    </columns>
    <columns>
        <field>Opportunity__c.AMOUNT</field>
    </columns>
    <columns>
        <field>Opportunity_Engagement_Signal__c.Match_Path__c</field>
    </columns>
    <columns>
        <field>Opportunity_Engagement_Signal__c.Confidence__c</field>
    </columns>
    <columns>
        <field>Opportunity_Engagement_Signal__c.Topic__c</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Asset_Name__c</field>
    </columns>
    <columns>
        <field>Engagement_Touch__c.Occurred_At__c</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>Opportunity__c.IS_CLOSED</column>
