<?xml version="1.0" encoding="UTF-8" ?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <description
  >Sales Manager view: engagement coverage across the open pipeline. Each row is an engagement signal grouped under its parent Opportunity, so a manager can spot Opps with zero engaged contacts, Opps with engaged contacts but none on the Deal Team (Match_Path != OCR), and Opps with strong coverage. Field paths follow Phase 5B documented conventions — if any path errors at runtime, edit the report in Setup, save, retrieve via SFDX, and reconcile.</description>
    <columns>
        <field>OPPORTUNITY.NAME</field>
    </columns>
    <columns>
        <field>OPPORTUNITY.STAGE_NAME</field>
    </columns>
    <columns>
        <field>OPPORTUNITY.AMOUNT</field>
    </columns>
    <columns>
        <field>OPPORTUNITY.CLOSE_DATE</field>
    </columns>
    <columns>
        <field>Opportunity.Engagement_Signals__r$Name</field>
    </columns>
    <columns>
        <field>Opportunity.Engagement_Signals__r$Match_Path__c</field>
    </columns>
    <columns>
        <field>Opportunity.Engagement_Signals__r$Confidence__c</field>
    </columns>
    <columns>
        <field>Opportunity.Engagement_Signals__r$Contact__c</field>
    </columns>
    <columns>
        <field>Opportunity.Engagement_Signals__r$Topic__c</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>OPPORTUNITY.IS_CLOSED</column>
            <operator>equals</operator>
            <value>0</value>
        </criteriaItems>
        <criteriaItems>
            <column>Opportunity.Engagement_Signals__r$Dismissed__c</column>
            <operator>notEqual</operator>
            <value>1</value>
        </criteriaItems>
    </filter>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>None</dateGranularity>
        <field>OPPORTUNITY.NAME</field>
