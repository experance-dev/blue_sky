#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# 1) Prettier + lint-staged (existing)
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ lint-staged failed — fix formatting/lint issues and re-commit"
  exit 1
fi

# 2) Salesforce Code Analyzer — pre-commit gate
#    Blocks on HIGH and MEDIUM (severity-threshold 2).
#    LOW passes pre-commit (caught at CI; pre-commit prioritizes speed).
#    Apex only at this stage (.cls / .trigger); LWC/JS handled in CI.
STAGED_APEX=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(cls|trigger)$' | tr '\n' ',' | sed 's/,$//')

if [ -n "$STAGED_APEX" ]; then
  echo ""
  echo "▶ Salesforce Code Analyzer on staged Apex (HIGH+MEDIUM blocks)..."
  mkdir -p reports
  sf code-analyzer run \
    --target "$STAGED_APEX" \
    --severity-threshold 2 \
    --output-file reports/scanner-precommit.json 2>&1 | tail -12
  STATUS=$?
  if [ $STATUS -ne 0 ]; then
    echo ""
    echo "❌ Code Analyzer found HIGH or MEDIUM severity issues."
    echo "   Per Zelis deployment gate, fix all findings before committing."
    echo "   Report: reports/scanner-precommit.json"
    echo "   Emergency bypass: git commit --no-verify (document why in commit msg)"
    exit 1
  fi
fi
